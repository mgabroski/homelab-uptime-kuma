{
  "name": "homelab-uptime-kuma",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore .yarn --ignore backups",
    "lint:yml": "yamllint .commitlintrc.yml .lintstagedrc.yml .markdownlint.yml .prettierrc.yml .yamllint.yml .yarnrc.yml docker-compose.yml",
    "lint-staged:check": "lint-staged --concurrent false",
    "validate": "yarn format && yarn lint:yml && yarn lint:md",
    "validate:check": "yarn format:check && yarn lint:yml && yarn lint:md"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "22.13.14",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3"
  }
}
